/ {
 #address-cells = <1>;
 #size-cells = <1>;

 cpus {
  #address-cells = <1>;
  #size-cells = <0>;

  cpu: cpu@0 {
   clock-frequency = <(((108) * 1000) * 1000)>;
   compatible = "nuclei,bumblebee", "riscv";
   riscv,isa = "rv32imac_zicsr_zifencei";
   reg = <0>;
  };
 };

 sram0: memory@20000000 {
  compatible = "mmio-sram";
 };

 soc {
  #address-cells = <1>;
  #size-cells = <1>;
  compatible = "simple-bus";
  interrupt-parent = <&eclic>;
  ranges;

  systimer: timer@d1000000 {
   compatible = "nuclei,systimer", "riscv,machine-timer";
   reg = <0xd1000000 0x8 0xd1000008 0x8>;
   reg-names = "mtime", "mtimecmp";
   interrupts-extended = <&eclic 7 0>;
   clk-divider = <2>;
  };

  eclic: interrupt-controller@d2000000 {
   compatible = "nuclei,eclic";
   #address-cells = <0>;
   #interrupt-cells = <2>;
   interrupt-controller;
   reg = <0xd2000000 0x2000>;
  };

  rcu: reset-clock-controller@40021000 {
   compatible = "gd,gd32-rcu";
   reg = <0x40021000 0x400>;
   status = "okay";

   cctl: clock-controller {
    compatible = "gd,gd32-cctl";
    #clock-cells = <1>;
    status = "okay";
   };

   rctl: reset-controller {
    compatible = "gd,gd32-rctl";
    #reset-cells = <1>;
    status = "okay";
   };
  };

  fmc: flash-controller@40022000 {
   compatible = "gd,gd32-flash-controller";
   reg = <0x40022000 0x400>;
   #address-cells = <1>;
   #size-cells = <1>;

   flash0: flash@8000000 {
    compatible = "gd,gd32-nv-flash-v1", "soc-nv-flash";
    write-block-size = <2>;
    max-erase-time-ms = <300>;
    page-size = <((1) * 1024)>;
   };
  };

  usart0: serial@40013800 {
   compatible = "gd,gd32-usart";
   reg = <0x40013800 0x400>;
   interrupts = <56 0>;
   clocks = <&cctl (((0x18U) << 6U) | (14U))>;
   resets = <&rctl (((0x0CU) << 6U) | (14U))>;
   status = "disabled";
  };

  usart1: serial@40004400 {
   compatible = "gd,gd32-usart";
   reg = <0x40004400 0x400>;
   interrupts = <57 0>;
   clocks = <&cctl (((0x1CU) << 6U) | (17U))>;
   resets = <&rctl (((0x10U) << 6U) | (17U))>;
   status = "disabled";
  };

  usart2: serial@40004800 {
   compatible = "gd,gd32-usart";
   reg = <0x40004800 0x400>;
   interrupts = <58 0>;
   clocks = <&cctl (((0x1CU) << 6U) | (18U))>;
   resets = <&rctl (((0x10U) << 6U) | (18U))>;
   status = "disabled";
  };

  uart3: serial@40004c00 {
   compatible = "gd,gd32-usart";
   reg = <0x40004c00 0x400>;
   interrupts = <71 0>;
   clocks = <&cctl (((0x1CU) << 6U) | (19U))>;
   resets = <&rctl (((0x10U) << 6U) | (19U))>;
   status = "disabled";
  };

  uart4: serial@40005000 {
   compatible = "gd,gd32-usart";
   reg = <0x40005000 0x400>;
   interrupts = <72 0>;
   clocks = <&cctl (((0x1CU) << 6U) | (20U))>;
   resets = <&rctl (((0x10U) << 6U) | (20U))>;
   status = "disabled";
  };

  adc0: adc@40012400 {
   compatible = "gd,gd32-adc";
   reg = <0x40012400 0x400>;
   interrupts = <37 0>;
   clocks = <&cctl (((0x18U) << 6U) | (9U))>;
   resets = <&rctl (((0x0CU) << 6U) | (9U))>;
   channels = <16>;
   status = "disabled";
   #io-channel-cells = <1>;
  };

  adc1: adc@40012800 {
   compatible = "gd,gd32-adc";
   reg = <0x40012800 0x400>;
   interrupts = <37 0>;
   clocks = <&cctl (((0x18U) << 6U) | (10U))>;
   resets = <&rctl (((0x0CU) << 6U) | (10U))>;
   channels = <16>;
   status = "disabled";
   #io-channel-cells = <1>;
  };

  dac: dac@40007400 {
   compatible = "gd,gd32-dac";
   reg = <0x40007400 0x400>;
   clocks = <&cctl (((0x1CU) << 6U) | (29U))>;
   resets = <&rctl (((0x10U) << 6U) | (29U))>;
   num-channels = <2>;
   status = "disabled";
   #io-channel-cells = <1>;
  };

  i2c0: i2c@40005400 {
   compatible = "gd,gd32-i2c";
   reg = <0x40005400 0x400>;
   #address-cells = <1>;
   #size-cells = <0>;
   clock-frequency = <100000>;
   interrupts = <50 0>, <51 0>;
   interrupt-names = "event", "error";
   clocks = <&cctl (((0x1CU) << 6U) | (21U))>;
   resets = <&rctl (((0x10U) << 6U) | (21U))>;
   status = "disabled";
  };

  spi0: spi@40013000 {
   compatible = "gd,gd32-spi";
   reg = <0x40013000 0x400>;
   interrupts = <54 0>;
   clocks = <&cctl (((0x18U) << 6U) | (12U))>;
   resets = <&rctl (((0x0CU) << 6U) | (12U))>;
   status = "disabled";
   #address-cells = <1>;
   #size-cells = <0>;
  };

  spi1: spi@40003800 {
   compatible = "gd,gd32-spi";
   reg = <0x40003800 0x400>;
   interrupts = <55 0>;
   clocks = <&cctl (((0x1CU) << 6U) | (14U))>;
   resets = <&rctl (((0x10U) << 6U) | (14U))>;
   status = "disabled";
   #address-cells = <1>;
   #size-cells = <0>;
  };

  afio: afio@40010000 {
   compatible = "gd,gd32-afio";
   reg = <0x40010000 0x400>;
   clocks = <&cctl (((0x18U) << 6U) | (0U))>;
   status = "okay";
  };

  exti: interrupt-controller@40010400 {
   compatible = "gd,gd32-exti";
   #address-cells = <0>;
   interrupt-controller;
   #interrupt-cells = <1>;
   reg = <0x40010400 0x400>;
   num-lines = <19>;
   interrupts = <25 0>, <26 0>, <27 0>, <28 0>, <29 0>,
         <42 0>, <59 0>;
   interrupt-names = "line0", "line1", "line2", "line3",
       "line4", "line5-9", "line10-15";
   status = "okay";
  };

  fwdgt: watchdog@40003000 {
   compatible = "gd,gd32-fwdgt";
   reg = <0x40003000 0x400>;
   status = "disabled";
  };

  wwdgt: watchdog@40002c00 {
   compatible = "gd,gd32-wwdgt";
   reg = <0x40002C00 0x400>;
   clocks = <&cctl (((0x1CU) << 6U) | (11U))>;
   resets = <&rctl (((0x10U) << 6U) | (11U))>;
   interrupts = <0 0>;
   status = "disabled";
  };

  pinctrl: pin-controller@40010800 {
   compatible = "gd,gd32-pinctrl-afio";
   reg = <0x40010800 0x1c00>;
   #address-cells = <1>;
   #size-cells = <1>;
   status = "okay";

   gpioa: gpio@40010800 {
    compatible = "gd,gd32-gpio";
    reg = <0x40010800 0x400>;
    gpio-controller;
    #gpio-cells = <2>;
    clocks = <&cctl (((0x18U) << 6U) | (2U))>;
    resets = <&rctl (((0x0CU) << 6U) | (2U))>;
    status = "disabled";
   };

   gpiob: gpio@40010c00 {
    compatible = "gd,gd32-gpio";
    reg = <0x40010c00 0x400>;
    gpio-controller;
    #gpio-cells = <2>;
    clocks = <&cctl (((0x18U) << 6U) | (3U))>;
    resets = <&rctl (((0x0CU) << 6U) | (3U))>;
    status = "disabled";
   };

   gpioc: gpio@40011000 {
    compatible = "gd,gd32-gpio";
    reg = <0x40011000 0x400>;
    gpio-controller;
    #gpio-cells = <2>;
    clocks = <&cctl (((0x18U) << 6U) | (4U))>;
    resets = <&rctl (((0x0CU) << 6U) | (4U))>;
    status = "disabled";
   };

   gpiod: gpio@40011400 {
    compatible = "gd,gd32-gpio";
    reg = <0x40011400 0x400>;
    gpio-controller;
    #gpio-cells = <2>;
    clocks = <&cctl (((0x18U) << 6U) | (5U))>;
    resets = <&rctl (((0x0CU) << 6U) | (5U))>;
    status = "disabled";
   };

   gpioe: gpio@40011800 {
    compatible = "gd,gd32-gpio";
    reg = <0x40011800 0x400>;
    gpio-controller;
    #gpio-cells = <2>;
    clocks = <&cctl (((0x18U) << 6U) | (6U))>;
    resets = <&rctl (((0x0CU) << 6U) | (6U))>;
    status = "disabled";
   };
  };

  timer0: timer@40012c00 {
   compatible = "gd,gd32-timer";
   reg = <0x40012c00 0x400>;
   interrupts = <43 0>, <44 0>, <45 0>, <46 0>;
   interrupt-names = "brk", "up", "trgcom", "cc";
   clocks = <&cctl (((0x18U) << 6U) | (11U))>;
   resets = <&rctl (((0x0CU) << 6U) | (11U))>;
   is-advanced;
   channels = <4>;
   status = "disabled";

   pwm {
    compatible = "gd,gd32-pwm";
    status = "disabled";
    #pwm-cells = <3>;
   };
  };

  timer1: timer@40000000 {
   compatible = "gd,gd32-timer";
   reg = <0x40000000 0x400>;
   interrupts = <47 0>;
   interrupt-names = "global";
   clocks = <&cctl (((0x1CU) << 6U) | (0U))>;
   resets = <&rctl (((0x10U) << 6U) | (0U))>;
   channels = <4>;
   status = "disabled";

   pwm {
    compatible = "gd,gd32-pwm";
    status = "disabled";
    #pwm-cells = <3>;
   };
  };

  timer2: timer@40000400 {
   compatible = "gd,gd32-timer";
   reg = <0x40000400 0x400>;
   interrupts = <48 0>;
   interrupt-names = "global";
   clocks = <&cctl (((0x1CU) << 6U) | (1U))>;
   resets = <&rctl (((0x10U) << 6U) | (1U))>;
   channels = <4>;
   status = "disabled";

   pwm {
    compatible = "gd,gd32-pwm";
    status = "disabled";
    #pwm-cells = <3>;
   };
  };

  timer3: timer@40000800 {
   compatible = "gd,gd32-timer";
   reg = <0x40000800 0x400>;
   interrupts = <49 0>;
   interrupt-names = "global";
   clocks = <&cctl (((0x1CU) << 6U) | (2U))>;
   resets = <&rctl (((0x10U) << 6U) | (2U))>;
   channels = <4>;
   status = "disabled";

   pwm {
    compatible = "gd,gd32-pwm";
    status = "disabled";
    #pwm-cells = <3>;
   };
  };

  timer4: timer@40000c00 {
   compatible = "gd,gd32-timer";
   reg = <0x40000c00 0x400>;
   interrupts = <69 0>;
   interrupt-names = "global";
   clocks = <&cctl (((0x1CU) << 6U) | (3U))>;
   resets = <&rctl (((0x10U) << 6U) | (3U))>;
   channels = <4>;
   status = "disabled";

   pwm {
    compatible = "gd,gd32-pwm";
    status = "disabled";
    #pwm-cells = <3>;
   };
  };

  timer5: timer@40001000 {
   compatible = "gd,gd32-timer";
   reg = <0x40001000 0x400>;
   interrupts = <73 0>;
   interrupt-names = "global";
   clocks = <&cctl (((0x1CU) << 6U) | (4U))>;
   resets = <&rctl (((0x10U) << 6U) | (4U))>;
   channels = <0>;
   status = "disabled";
  };

  timer6: timer@40001400 {
   compatible = "gd,gd32-timer";
   reg = <0x40001400 0x400>;
   interrupts = <74 0>;
   interrupt-names = "global";
   clocks = <&cctl (((0x1CU) << 6U) | (5U))>;
   resets = <&rctl (((0x10U) << 6U) | (5U))>;
   channels = <0>;
   status = "disabled";
  };

  dma0: dma@40020000 {
   compatible = "gd,gd32-dma";
   reg = <0x40020000 0x400>;
   interrupts = <30 0>, <31 0>, <32 0>, <33 0>,
         <34 0>, <35 0>, <36 0>;
   clocks = <&cctl (((0x14U) << 6U) | (0U))>;
   dma-channels = <7>;
   gd,mem2mem;
   #dma-cells = <2>;
   status = "disabled";
  };

  dma1: dma@40020400 {
   compatible = "gd,gd32-dma";
   reg = <0x40020400 0x400>;
   interrupts = <75 0>, <76 0>, <77 0>, <78 0>,
         <79 0>;
   clocks = <&cctl (((0x14U) << 6U) | (1U))>;
   dma-channels = <5>;
   gd,mem2mem;
   #dma-cells = <2>;
   status = "disabled";
  };
 };
};
